# ======================================================================================================================
# Scripts - Base - Default variables
# ======================================================================================================================

# >>>> Platform                                                              https://www.php.net/manual/en/timezones.php
PLATFORM_TIMEZONE="Asia/Seoul"

# ----------------------------------------------------------------------------------------------------------------------
# Software Bundles
# ----------------------------------------------------------------------------------------------------------------------

# >>>> App
PHP_VERSION=8.3
PHP_FRAMEWORK_VERSION=7.1.*

NODE_VERSION=20

# >>>> Cache
REDIS_VERSION=6.0

# >>>> Database
POSTGRES_VERSION=14.8

# >>>> Message
RABBITMQ_VERSION=3.13

# >>>> Server
NGINX_VERSION=1.18

# ----------------------------------------------------------------------------------------------------------------------
# CDN - Content Delivery Networks
# ----------------------------------------------------------------------------------------------------------------------


# ----------------------------------------------------------------------------------------------------------------------
# Docker - Containers
# ----------------------------------------------------------------------------------------------------------------------
DOCKER_CONTAINER_NAME=symfony

# ----------------------------------------------------------------------------------------------------------------------
# VM - Instance
# ----------------------------------------------------------------------------------------------------------------------


# ----------------------------------------------------------------------------------------------------------------------
# Tools
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Git
GIT_REMOTE_ORIGIN_URL="https://github.com/xsuntel/symfony-scripts"
GIT_CONFIG_LOCAL_USER_NAME="Ryan Lim"
GIT_CONFIG_LOCAL_USER_EMAIL="your_email_address"

# >>>> IDE - PhpStorm                                                        https://www.jetbrains.com/phpstorm/download
OPENJDK_VERSION=17
PHPSTORM_VERSION=2024.1