# ======================================================================================================================
# Scripts - Default variables
# ======================================================================================================================

# >>>> Platform                                                              https://www.php.net/manual/en/timezones.php
PLATFORM_TIMEZONE="Asia/Seoul"

# >>>> Project
PROJECT_DOMAIN="symfony.com"

# ----------------------------------------------------------------------------------------------------------------------
# Bundles
# ----------------------------------------------------------------------------------------------------------------------

# >>>> App      - PHP                                                                       https://symfony.com/releases
PHP_VERSION=8.4
SYMFONY_VERSION=8.0.*

NODE_VERSION=24

# >>>> Cache    - Redis
REDIS_VERSION=7.0

# >>>> Database - PostgreSQL
POSTGRES_VERSION=16

# >>>> Message  - RabbitMQ
RABBITMQ_VERSION=3.13

# >>>> Server   - Nginx
NGINX_VERSION=1.24

# ----------------------------------------------------------------------------------------------------------------------
# CDN - Content Delivery Networks
# ----------------------------------------------------------------------------------------------------------------------

# >>>> AWS (Amazon Web Services)
AWS_S3_DOMAIN=
AWS_S3_KEY=
AWS_S3_SECRET=
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_VERSION=

# >>>> GCP (Google Cloud Platform)

# ----------------------------------------------------------------------------------------------------------------------
# Docker - Containers
# ----------------------------------------------------------------------------------------------------------------------
DOCKER_CONTAINER_NAME=symfony

# >>>> Dockerfile
DOCKERFILE_IMAGE_NAME=${PROJECT_DOMAIN}
DOCKERFILE_TAG_NAME=

# ----------------------------------------------------------------------------------------------------------------------
# Provider - Cloud Service Provider
# ----------------------------------------------------------------------------------------------------------------------

# >>>> AWS (Amazon Web Services)
AWS_CLI_VERSION=

AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

# >>>> GCP (Google Cloud Platform)

GCLOUD_PROJECT_ID=
GCLOUD_ARTIFACT_NAME=
GCLOUD_ARTIFACT_LOCATION=
GCLOUD_ARTIFACT_DESCRIPTION=
GCLOUD_ARTIFACT_TAG=

# ----------------------------------------------------------------------------------------------------------------------
# VM - Instance
# ----------------------------------------------------------------------------------------------------------------------

PYTHON_VERSION=

# ----------------------------------------------------------------------------------------------------------------------
# Tools
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Git
GIT_REMOTE_ORIGIN_URL=""
GIT_CONFIG_LOCAL_USER_NAME=""
GIT_CONFIG_LOCAL_USER_EMAIL=""
