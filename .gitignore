# ----------------------------------------------------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------------------------------------------------
# >>>> asset-mapper
app/assets/styles/app.tailwind.css
app/assets/vendor
app/bin/tailwindcss-linux-x64

# >>>> app/config
app/config/secrets/prod/prod.decrypt.private.php
app/config/jwt/*.pem

# >>>> app/migrations
app/migrations

# >>>> app/node_modules
app/node_modules/

# >>>> app/public
app/public/assets/
app/public/build/
app/public/bundles/
app/public/download/

# >>>> app/tests
!app/tests/bootstrap.php
!app/tests/

# >>>> app/var
app/var/

# >>>> app/vendor
app/vendor/

# >>>> app/.env.*
app/.env.*
app/.env.*.*
app/.env.local
app/.env.local.php
app/.env.*.local

# >>>> app/composer
app/composer.phar
app/composer.lock

# >>>> app/package
app/package.tar
app/packages.json
app/package-lock.json

# >>>> app/phpunit.*
app/phpunit.xml
app/.phpunit
app/.phpunit.result.cache

# >>>> php-cs-fixer/shim
app/.php-cs-fixer.php
app/.php-cs-fixer.cache

# >>>> PHP - phing
app/phing-latest.phar

# >>>> app/*.log
app/*.log

# >>>> app/*.json
app/webpack-stats.json

