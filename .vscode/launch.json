{
    "version": "0.2.0",
    "configurations": [
        // -------------------------------------------------------------------------------
        // Debug - PHP
        // -------------------------------------------------------------------------------
        {
            "name": "1. Listen for Xdebug (PHP)",
            "type": "php",
            "request": "launch",
            "hostname": "localhost",
            "port": 9003,
            "pathMappings": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        },
        // -------------------------------------------------------------------------------
        // Debug - Javascript
        // -------------------------------------------------------------------------------
        {
            "name": "2. Launch Chrome (Frontend)",
            "type": "chrome",
            "request": "launch",
            "url": "http://127.0.0.1:8000",                       // Symfony Local Server
            "webRoot": "${workspaceFolder}",
            "sourceMapPathOverrides": {
                "webpack:///*": "${workspaceFolder}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack Debugging (PHP + Javascript)",
            "configurations": ["1. Listen for Xdebug (PHP)", "2. Launch Chrome (Frontend)"]
        }
    ]
}
