# ======================================================================================================================
# Docker - Docker-Compose                                                   https://docs.docker.com/compose/compose-file
# ======================================================================================================================
# >>>> Dev Environment                                                            TCP Port numbers range from 0 to 65536
DOCKER_ENVIRONMENT=dev

DOCKER_NETWORK_FRONTEND_IPAM_CONFIG_SUBNET=172.11.0.0/24
DOCKER_NETWORK_BACKEND_IPAM_CONFIG_SUBNET=172.21.0.0/24

# >>>> Project
DOCKER_PROJECT_NAME=dev
DOCKER_WORKDIR="/var/www/app"

# ----------------------------------------------------------------------------------------------------------------------
# Architecture
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Cache - Redis - Docker - Network - Back-End IP Address
REDIS_NETWORK_BACKEND_IP_ADDRESS=172.21.0.21
REDIS_NETWORK_PORT=6379
REDIS_HOST=${REDIS_NETWORK_BACKEND_IP_ADDRESS}
REDIS_PORT=6379

# >>>> Database - PostgreSQL - Docker - Network - Back-End IP Address
POSTGRES_NETWORK_BACKEND_IP_ADDRESS=172.21.0.31
POSTGRES_NETWORK_PORT=5432
POSTGRES_HOST=${POSTGRES_NETWORK_BACKEND_IP_ADDRESS}
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=symfony
POSTGRES_PASSWORD=!ChangeMe!

# >>>> Message - RabbitMQ - Docker - Network - Back-End IP Address
RABBITMQ_NETWORK_BACKEND_IP_ADDRESS=172.21.0.41
RABBITMQ_NETWORK_PORT=5672
RABBITMQ_HOST=${RABBITMQ_NETWORK_BACKEND_IP_ADDRESS}
RABBITMQ_PORT=5672

# ----------------------------------------------------------------------------------------------------------------------
# Tools
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Kafka - Docker - Network


# ----------------------------------------------------------------------------------------------------------------------
# Utility
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Database - pgAdmin - Docker - Network                                     https://hub.docker.com/r/dpage/pgadmin4
PGADMIN_NETWORK_FRONTEND_IP_ADDRESS=172.11.0.61
PGADMIN_NETWORK_BACKEND_IP_ADDRESS=172.21.0.61
PGADMIN_NETWORK_PORT=5433
PGADMIN_HOST=${PGADMIN_NETWORK_BACKEND_IP_ADDRESS}
PGADMIN_DEFAULT_EMAIL=pgadmin@example.com
PGADMIN_DEFAULT_PASSWORD=!ChangeMe!
PGADMIN_MAIL=${PGADMIN_DEFAULT_EMAIL}
PGADMIN_PW=${PGADMIN_DEFAULT_PASSWORD}

# >>>> Utility - Mailer - Docker - Network                               https://hub.docker.com/r/schickling/mailcatcher
MAILER_NETWORK_FRONTEND_IP_ADDRESS=172.11.0.71
MAILER_NETWORK_BACKEND_IP_ADDRESS=172.21.0.71
MAILER_NETWORK_HTTP_PORT=1180
MAILER_NETWORK_SMTP_PORT=1125
