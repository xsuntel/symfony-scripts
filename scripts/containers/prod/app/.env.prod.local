# >>>> Cache - Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# >>>> Database - PostgreSQL
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# >>>> Message - RabbitMQ
RABBITMQ_HOST=host.docker.internal
RABBITMQ_PORT=5672

