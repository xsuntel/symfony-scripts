# ======================================================================================================================
# Scripts - Base - Default variables
# ======================================================================================================================
# >>>> Environment
ENVIRONMENT_NAME="dev"

# >>>> Platform
PLATFORM_TIMEZONE="Asia/Seoul"

# >>>> Project                                                                                             Folder's name
PROJECT_NAME=symfony

# ----------------------------------------------------------------------------------------------------------------------
# Web Server
# ----------------------------------------------------------------------------------------------------------------------
# >>>> App
PHP_VERSION=8.3
PHP_FRAMEWORK_VERSION=7.0.*
NODE_VERSION=20

# >>>> Cache
REDIS_VERSION=6.0

# >>>> Database
POSTGRES_VERSION=14.8

# >>>> Server
NGINX_VERSION=1.18

# ----------------------------------------------------------------------------------------------------------------------
# Content Delivery
# ----------------------------------------------------------------------------------------------------------------------
# >>>> AWS - CDN - S3                                                                             https://aws.amazon.com
#AMAZON_S3_BUCKET=bucket-symfony

# ----------------------------------------------------------------------------------------------------------------------
# Instance
# ----------------------------------------------------------------------------------------------------------------------


# ----------------------------------------------------------------------------------------------------------------------
# Container
# ----------------------------------------------------------------------------------------------------------------------


# ----------------------------------------------------------------------------------------------------------------------
# Tools
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Git
GIT_REMOTE_ORIGIN_URL="https://github.com/xsuntel/symfony-scripts"
GIT_CONFIG_GLOBAL_USER_NAME="Ryan Lim"
GIT_CONFIG_GLOBAL_USER_EMAIL="xsuntel@gmail.com"

# >>>> IDE - PhpStorm                                                        https://www.jetbrains.com/phpstorm/download
OPENJDK_VERSION=17
PHPSTORM_VERSION=2023.3.5