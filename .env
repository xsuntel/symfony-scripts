# ======================================================================================================================
# Scripts - Base - Default variables
# ======================================================================================================================
# >>>> Abstract    - Folder's name
ABSTRACT_NAME=symfony

# >>>> Environment - Dev - Ngnix - Server's name
ENVIRONMENT_LOCAL_SERVER_NAME=symfony.local

# >>>> Platform
PLATFORM_TIMEZONE="Asia/Seoul"

# >>>> Project
GIT_REMOTE_ORIGIN_URL="https://github.com/xsuntel/symfony-scripts"
GIT_CONFIG_GLOBAL_USER_NAME="Ryan Lim"
GIT_CONFIG_GLOBAL_USER_EMAIL="symfony@example.com"

# ----------------------------------------------------------------------------------------------------------------------
# App                                                                                       https://symfony.com/releases
# ----------------------------------------------------------------------------------------------------------------------
# >>>> PHP                                                                                               https://php.net
PHP_VERSION=8.1

# ----------------------------------------------------------------------------------------------------------------------
# Cache
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Redis                                                                                           https://redis.com
REDIS_VERSION=6.0

# ----------------------------------------------------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------------------------------------------------
# >>>> PostgreSQL                                                                             https://www.postgresql.org
POSTGRES_VERSION=14.8

# ----------------------------------------------------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Nginx                                                                                           https://nginx.org
NGINX_VERSION=1.18

# >>>> AWS - CDN - S3                                                                             https://aws.amazon.com
#AMAZON_S3_BUCKET=bucket-symfony

# ----------------------------------------------------------------------------------------------------------------------
# Tools
# ----------------------------------------------------------------------------------------------------------------------
# >>>> IDE - PhpStorm                                                        https://www.jetbrains.com/phpstorm/download
OPENJDK_VERSION=17
PHPSTORM_VERSION=2023.3.2