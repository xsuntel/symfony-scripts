# ======================================================================================================================
# Symfony Framework - Dev Environment
# ======================================================================================================================
# >>>> Environment
APP_ENV=dev
APP_SECRET=symfony_dev_secret
APP_DEBUG=1

# ----------------------------------------------------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Local  URL
LOCAL_URL_SCHEME=http
LOCAL_URL_HOST=127.0.0.1
LOCAL_URL_PORT=80

# >>>> Public URL
PUBLIC_URL_SCHEME=http
PUBLIC_URL_HOST=127.0.0.1
PUBLIC_URL_PORT=80

# ----------------------------------------------------------------------------------------------------------------------
# Cache
# ----------------------------------------------------------------------------------------------------------------------
# >>>> Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ----------------------------------------------------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------------------------------------------------
# >>>> PostgreSQL
POSTGRES_VERSION=14
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=symfony
POSTGRES_PASSWORD=!ChangeMe!

# ----------------------------------------------------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------------------------------------------------
# >>>> AWS - S3                         https://symfony.com/bundles/LiipImagineBundle/current/cache-resolver/aws_s3.html
AMAZON_S3_DOMAIN=null
AMAZON_S3_KEY=null
AMAZON_S3_SECRET=null
AMAZON_S3_BUCKET=null
AMAZON_S3_REGION=null
AMAZON_S3_VERSION=null

# >>>> AWS - SES
MAILER_ACCESS_KEY=null
MAILER_SECRET_KEY=null
